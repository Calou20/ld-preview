---
import '../styles/global.css';
import { t } from '../i18n';
import { url } from '../lib/url';
import Preloader from '../components/Preloader.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import NavPill from '../components/NavPill.astro';

interface Props {
  pageTitle?: string;
  pageDescription?: string;
  hidePreloader?: boolean;
}

const { pageTitle, pageDescription, hidePreloader = false } = Astro.props;
const dict = t();
const title = pageTitle ?? dict.meta.title;
const description = pageDescription ?? dict.meta.description;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="preload" as="image" href={url('/images/verines.webp')} fetchpriority="high" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={url('/images/logo-black.webp')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,WONK@9..144,300..700,0&family=DM+Sans:opsz,wght@9..40,300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top" class="bg-black overflow-x-hidden">
    {!hidePreloader && <Preloader />}
    <NavPill />
    <SmoothScroll />
    <main>
      <slot />
    </main>

    <!-- Bouton Retour en haut -->
    <a
      href="#top"
      id="back-to-top"
      class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-[999] flex h-12 w-12 items-center justify-center rounded-full bg-black/70 backdrop-blur-md border border-white/20 text-white shadow-2xl transition-all duration-500 hover:bg-white/20 hover:scale-105"
      style="opacity: 0; pointer-events: none; transform: translateY(10px);"
      aria-label="Back to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 19V5" />
        <path d="M5 12l7-7 7 7" />
      </svg>
    </a>

    <script>
      const btn = document.getElementById('back-to-top');
      if (btn) {
        const onScroll = () => {
          if (window.scrollY > 200) {
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
            btn.style.transform = 'translateY(0)';
          } else {
            btn.style.opacity = '0';
            btn.style.pointerEvents = 'none';
            btn.style.transform = 'translateY(10px)';
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        setTimeout(onScroll, 100);
      }
    </script>
  </body>
</html>
