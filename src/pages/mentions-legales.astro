---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n';
import { url } from '../lib/url';

const dict = t();
---

<BaseLayout pageTitle={`${dict.legal.title} — LD`}>
  <article class="section container-page max-w-3xl">
    <h1 class="font-serif text-4xl md:text-5xl font-light mb-8">{dict.legal.title}</h1>
    <p class="text-[var(--color-muted)] leading-relaxed mb-12 whitespace-pre-line">
      {dict.legal.body}
    </p>
    <a href={url('/')} class="inline-block text-sm uppercase tracking-wider border-b border-current pb-1 hover:text-[var(--color-accent)]">
      ← {dict.legal.back}
    </a>
  </article>
  <Footer />
</BaseLayout>
