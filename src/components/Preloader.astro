---
---

<div
  id="preloader"
  class="fixed inset-0 z-[100] flex items-end justify-end bg-black text-white"
  aria-hidden="true"
>
  <div class="p-8 md:p-12 flex items-baseline gap-2">
    <span
      id="preloader-count"
      class="font-serif text-7xl md:text-9xl leading-none tabular-nums"
      style="color: var(--color-accent);">0</span
    >
    <span class="text-2xl md:text-3xl text-white/60">%</span>
  </div>
</div>

<script>
  const el = document.getElementById('preloader');
  const count = document.getElementById('preloader-count');
  if (el && count && !new URLSearchParams(location.search).has('nopreload')) {
    const start = performance.now();
    const duration = 1400;
    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);
      count!.textContent = Math.round(eased * 100).toString();
      if (t < 1) {
        requestAnimationFrame(tick);
      } else {
        el!.style.transition = 'transform 800ms cubic-bezier(0.77,0,0.175,1)';
        el!.style.transform = 'translateY(-100%)';
        setTimeout(() => {
          el!.remove();
          document.documentElement.classList.remove('preloading');
          document.documentElement.dispatchEvent(new Event('preloader:done'));
        }, 850);
      }
    }
    document.documentElement.classList.add('preloading');
    requestAnimationFrame(tick);
  } else if (el) {
    el.remove();
    document.documentElement.dispatchEvent(new Event('preloader:done'));
  }
</script>

<style is:global>
  html.preloading,
  html.preloading body {
    overflow: hidden;
  }
</style>
