---
import { t } from '../i18n';
import { url } from '../lib/url';

const dict = t();
const bar = dict.bar;

const visuals = [
  { src: url('/images/dju/frisson.png'), seasonal: false, glow: '#e8b53d' },
  { src: url('/images/dju/evidence.png'), seasonal: false, glow: '#b53d6f' },
  { src: url('/images/dju/eveil.png'), seasonal: false, glow: '#d97a3d' },
  { src: url('/images/dju/audacieux.png'), seasonal: true, glow: '#c43b2c' },
];

const drinks = bar.drinks.map((d, i) => ({
  ...d,
  src: visuals[i].src,
  seasonal: visuals[i].seasonal,
  glow: visuals[i].glow,
}));
---

<section id="bar" class="relative bg-[var(--color-ink)] text-white overflow-hidden">
  <div
    class="absolute inset-0 -z-10 pointer-events-none opacity-30"
    style="background: radial-gradient(60% 60% at 80% 20%, rgba(201,163,106,0.35) 0%, transparent 60%), radial-gradient(50% 50% at 10% 90%, rgba(201,163,106,0.15) 0%, transparent 70%);"
  >
  </div>

  <div class="container-page py-24 md:py-32 lg:py-36 space-y-20 md:space-y-28">
    {/* Bloc 1 — Service Bar */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-6 space-y-8">
        <p
          class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.3em] text-white/70 px-4 py-2 rounded-full border border-white/15 bg-white/[0.03] backdrop-blur-sm"
        >
          <span
            class="inline-block w-1.5 h-1.5 rounded-full"
            style="background: var(--color-accent);"></span>
          {bar.eyebrow}
        </p>

        <h2
          class="font-serif text-4xl md:text-5xl lg:text-6xl font-light leading-[1.05] uppercase tracking-tight"
        >
          {bar.title}
        </h2>

        <p class="text-base md:text-lg text-white/70 leading-relaxed max-w-lg">
          {bar.intro}
        </p>
      </div>

      <div class="lg:col-span-6">
        <div class="rounded-3xl overflow-hidden border border-white/10">
          <img
            src={url('/images/wine-glasses.png')}
            alt=""
            loading="lazy"
            class="w-full h-64 md:h-80 lg:h-96 object-cover"
          />
        </div>
      </div>
    </div>

    {/* Bloc 2 — Option signature DJU */}
    <div class="space-y-10 md:space-y-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5 flex justify-center lg:justify-start order-1">
          <img
            src={url('/images/logoDJU.png')}
            alt="DJU"
            loading="lazy"
            class="w-48 md:w-64 lg:w-72 h-auto object-contain"
          />
        </div>

        <div class="lg:col-span-7 space-y-6 order-2 lg:text-right flex flex-col lg:items-end">
          <p
            class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.3em] text-white/70 px-4 py-2 rounded-full border border-white/15 bg-white/[0.03] backdrop-blur-sm self-start lg:self-end"
          >
            <span
              class="inline-block w-1.5 h-1.5 rounded-full"
              style="background: var(--color-accent);"></span>
            {bar.signatureEyebrow}
          </p>

          <h3
            class="font-serif text-3xl md:text-4xl lg:text-5xl font-light leading-[1.1] uppercase tracking-tight whitespace-pre-line"
          >
            {bar.signatureTitle}
          </h3>

          <p class="text-base md:text-lg text-white/70 leading-relaxed max-w-xl">
            {bar.signatureIntro.map((seg) => (
              <span style={seg.highlight ? 'color: var(--color-accent);' : ''}>{seg.text}</span>
            ))}
          </p>
        </div>
      </div>

      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 border border-white/10 rounded-3xl overflow-hidden">
        {
          drinks.map((d) => (
            <li
              class="relative bg-[var(--color-ink)] aspect-square flex flex-col p-5 md:p-7 group overflow-hidden"
              style={`--glow: ${d.glow};`}
            >
              {d.seasonal && (
                <span
                  class="absolute top-0 right-0 z-20 text-[10px] md:text-[11px] uppercase tracking-[0.2em] font-medium px-2.5 py-1 rounded-bl-xl text-black"
                  style="background: var(--color-accent);"
                >
                  {bar.seasonalLabel}
                </span>
              )}

              <div class={`relative z-10 ${d.seasonal ? 'pr-24 md:pr-28' : ''}`}>
                <p class="font-serif text-2xl md:text-3xl font-light leading-tight group-hover:text-[var(--color-accent)] transition-colors duration-500">
                  {d.name}
                </p>
                <p class="mt-1.5 text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-white/55 leading-relaxed max-w-[22ch]">
                  {d.ingredients}
                </p>
              </div>

              <div class="absolute inset-x-0 bottom-0 h-[52%] md:h-[60%] lg:h-[68%] flex items-end justify-center pb-3 md:pb-4 pointer-events-none">
                <img
                  src={d.src}
                  alt={d.name}
                  loading="lazy"
                  class="cocktail-img max-h-full w-auto object-contain drop-shadow-[0_18px_24px_rgba(0,0,0,0.6)] transition-all duration-500 ease-out group-hover:scale-[1.06] group-hover:-translate-y-1"
                />
              </div>

              <span
                aria-hidden="true"
                class="absolute inset-0 -z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                style={`background: radial-gradient(ellipse 60% 45% at 50% 72%, ${d.glow}66 0%, ${d.glow}33 32%, ${d.glow}11 58%, transparent 82%);`}
              />
            </li>
          ))
        }
      </ul>

      <div>
        <a
          href={bar.djuCtaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-4 pl-7 pr-2 py-2 rounded-full text-black font-medium transition-transform hover:scale-[1.02]"
          style="background: var(--color-accent);"
        >
          <span>{bar.djuCta}</span>
          <span
            class="flex items-center justify-center w-10 h-10 rounded-full bg-black/10 group-hover:bg-black/20 transition-colors"
            aria-hidden="true">↗</span
          >
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #bar li:hover .cocktail-img {
    filter: drop-shadow(0 0 16px var(--glow)) drop-shadow(0 18px 24px rgba(0, 0, 0, 0.6));
  }
</style>
