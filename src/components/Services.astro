---
import { t } from '../i18n';

const dict = t();

const photos = [
  '/images/canapes.jpg',
  '/images/sable-mousse.jpg',
  '/images/humus.jpg',
];
---

<section id="services" class="section bg-[var(--color-cream)]">
  <div class="container-page">
    <div class="max-w-2xl mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-6">{dict.services.title}</h2>
      <p class="text-lg text-[var(--color-muted)] leading-relaxed">{dict.services.intro}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {
        dict.services.items.map((item, i) => (
          <article class="group relative bg-white p-8 md:p-10 border border-black/5 hover:border-[var(--color-accent)] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl overflow-hidden">
            <div class="absolute top-0 right-0 w-20 h-20 bg-[var(--color-accent)]/10 rounded-full -translate-y-10 translate-x-10 group-hover:scale-150 transition-transform duration-700 ease-out"></div>

            <div class="relative z-10 flex items-start gap-4 mb-6">
              <div class="text-[var(--color-accent)] font-serif text-3xl group-hover:scale-110 origin-left transition-transform duration-500">
                0{i + 1}
              </div>
              <div class="ml-auto w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden border-2 border-white shadow-md ring-1 ring-black/5 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 ease-out">
                <img
                  src={photos[i]}
                  alt=""
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>

            <div class="relative z-10">
              <h3 class="font-serif text-2xl font-medium mb-4 group-hover:text-[var(--color-accent)] transition-colors duration-500">{item.title}</h3>
              <p class="text-[var(--color-muted)] leading-relaxed">{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>

    <aside class="mt-12 md:mt-16 p-6 md:p-8 border-l-2 border-[var(--color-accent)] bg-white">
      <h4 class="font-medium mb-2">{dict.services.noteTitle}</h4>
      <p class="text-[var(--color-muted)]">{dict.services.note}</p>
    </aside>
  </div>
</section>
