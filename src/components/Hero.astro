---
import { t } from '../i18n';

const dict = t();
const segments = dict.hero.titleSegments;
---

<section
  id="hero"
  class="relative isolate min-h-screen flex flex-col justify-center overflow-hidden text-white"
>
  <div
    class="absolute inset-0 -z-10 bg-black"
    style="background-image: url('/images/background.jpg'); background-size: cover; background-position: center;"
  >
  </div>
  <div
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.55) 45%, rgba(0,0,0,0.9) 100%);"
  >
  </div>
  <div
    class="absolute inset-0 -z-10 pointer-events-none"
    style="background: radial-gradient(120% 80% at 30% 40%, transparent 0%, rgba(0,0,0,0.3) 70%, rgba(0,0,0,0.55) 100%);"
  >
  </div>

  <div class="container-page pb-12 md:pb-16">
    <h1
      class="hero-title font-serif font-light leading-[0.95] tracking-tight uppercase text-[clamp(2rem,8vw,9.5rem)] max-w-[18ch] break-words"
    >
      {
        segments.map((seg) => (
          <span class="hero-word inline-block overflow-hidden align-bottom">
            <span
              class="inline-block"
              style={seg.highlight ? 'color: var(--color-accent);' : ''}
            >
              {seg.text}
            </span>
          </span>
        ))
      }
    </h1>

    <p
      class="hero-sub mt-8 md:mt-10 max-w-xl text-lg md:text-xl text-white/80 leading-relaxed"
    >
      {dict.hero.subtitle}
    </p>

    <div class="hero-ctas mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="#contact"
        class="group inline-flex items-center justify-between gap-4 pl-7 pr-2 py-2 rounded-full text-black font-medium transition-transform hover:scale-[1.02]"
        style="background: var(--color-accent);"
      >
        <span>{dict.hero.ctaPrimary}</span>
        <span
          class="flex items-center justify-center w-10 h-10 rounded-full bg-black/10 group-hover:bg-black/20 transition-colors"
          >→</span
        >
      </a>
      <a
        href="#approach"
        class="inline-flex items-center justify-center px-7 py-4 rounded-full border border-white/30 text-white hover:bg-white/10 transition-colors"
      >
        {dict.hero.ctaSecondary}
      </a>
    </div>
  </div>

  <div
    class="hero-scroll absolute bottom-6 left-1/2 -translate-x-1/2 text-xs uppercase tracking-[0.3em] text-white/50 hidden md:flex flex-col items-center gap-2"
  >
    <span>Scroll</span>
    <span class="w-px h-8 bg-white/30 block"></span>
  </div>
</section>

<style>
  #hero .hero-sub,
  #hero .hero-ctas > *,
  #hero .hero-scroll,
  #hero .hero-word > span {
    opacity: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';

  function reveal() {
    gsap.set('.hero-word > span', { yPercent: 110 });
    gsap.set('.hero-sub, .hero-scroll', { y: 20 });

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.to(
        '.hero-word > span',
        { yPercent: 0, opacity: 1, duration: 1.1, stagger: 0.08, ease: 'expo.out' }
      )
      .to('.hero-sub', { y: 0, opacity: 1, duration: 0.7 }, '-=0.6')
      .to('.hero-ctas > *', { opacity: 1, duration: 0.6 }, '-=0.4')
      .to('.hero-scroll', { opacity: 1, duration: 0.6 }, '-=0.2');
  }

  function start() {
    if (document.getElementById('preloader')) {
      document.documentElement.addEventListener('preloader:done', reveal, { once: true });
    } else {
      reveal();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start, { once: true });
  } else {
    start();
  }
</script>
